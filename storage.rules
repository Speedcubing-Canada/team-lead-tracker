rules_version = '2';

// Person photos uploaded by delegates so stage leads can match a name to a face.
// Access mirrors firestore.rules: any member of the competition may read; only
// privileged members (delegates/organizers, per the `privileged` flag on their
// membership doc) may write. Membership is read cross-service via firestore.get.
service firebase.storage {
  match /b/{bucket}/o {
    function memberDoc(compId) {
      return firestore.get(
        /databases/(default)/documents/competitions/$(compId)/members/$(request.auth.uid)
      );
    }

    match /competitions/{compId}/people/{fileName} {
      allow read: if request.auth != null
        && firestore.exists(
          /databases/(default)/documents/competitions/$(compId)/members/$(request.auth.uid)
        );

      allow write: if request.auth != null
        && memberDoc(compId).data.privileged == true
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 2 * 1024 * 1024;

      allow delete: if request.auth != null
        && memberDoc(compId).data.privileged == true;
    }
  }
}
