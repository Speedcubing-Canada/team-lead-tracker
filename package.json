{
  "name": "team-lead-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "emulators": "FUNCTIONS_DISCOVERY_TIMEOUT=60 firebase emulators:start",
    "deploy": "npm run build && npm run test && firebase deploy --only hosting",
    "deploy:functions": "npm --prefix functions run build && FUNCTIONS_DISCOVERY_TIMEOUT=60 firebase deploy --only functions"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@tanstack/react-query": "^5.59.16",
    "firebase": "^11.0.2",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "firebase-tools": "^15.20.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^3.0.0"
  }
}
