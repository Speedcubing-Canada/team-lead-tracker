# Copy to .env.local and fill in. Vite only exposes VITE_-prefixed vars to the client.

# --- Firebase (client config; safe to expose, security is enforced by rules) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- WCA OAuth (public client info only; the client SECRET lives in the Cloud Function) ---
VITE_WCA_ORIGIN=https://www.worldcubeassociation.org
VITE_WCA_CLIENT_ID=
VITE_WCA_REDIRECT_URI=http://localhost:5173/auth/callback
